# ============================================================
# MOOP App Repo .gitignore
#
# This repo contains only the application code needed to set up
# a new MOOP site. Site-specific data (config overrides, metadata,
# user accounts) is versioned separately — see lib/housekeeping.php
# and config/site_config.php -> site_data_path.
# ============================================================

# ── Genome data (too large for git) ──────────────────────────
*.fa
*.fasta
*.fai
*.fa.gz
*.fasta.gz
*.gff3
*.gff3.gz
*.gff3.gz.tbi
data/genomes/
data/tracks/*
!data/tracks/.htaccess

# ── Database files ───────────────────────────────────────────
*.sqlite
*.sqlite3

# ── Site-specific config (managed by admin UI) ───────────────
config/config_editable.json
config/secrets.php

# ── Site-specific metadata (managed by admin UI) ─────────────
# Keep .example templates and README, ignore actual data files
metadata/*.json
!metadata/*.json.example
metadata/backups/
metadata/jbrowse2-configs/
metadata/change_log/
# NCBI taxonomy dump — large binary, downloaded by sync_ncbi_taxonomy_dump.php
metadata/ncbi_rankedlineage.dmp.gz
metadata/.ncbi_taxonomy_meta.json

# ── Logs and runtime state ───────────────────────────────────
logs/

# ── Backup files ─────────────────────────────────────────────
*bak
*BAK
*.bak.*
*.backup
*~
admin/backups/

# ── Archive / old configs ────────────────────────────────────
api/archive/

# ── Dependencies (installed via composer install) ────────────
vendor/
composer.phar

# ── Organisms (site data, managed outside app repo) ─────────
organisms/*
!organisms/README.md
!organisms/ORGANISM_DISPLAY_README.md

# ── Images (site-specific uploads) ───────────────────────────
images/*
!images/.gitkeep

# ── JBrowse2 generated configs ──────────────────────────────
jbrowse2/configs/

# ── Secrets and credentials (NEVER COMMIT) ───────────────────
*_api_key*
*.key
*.pem

# ── Test files ───────────────────────────────────────────────
test_*.php
test_*.sh
test_*.json
test-*.php
galaxy_testing/

# ── Build/cache artifacts ────────────────────────────────────
__pycache__/
*.pyc
.php-cs-fixer.cache
tmp/
temp/
tools/not_using/
not_used/

# ── Installer token (generated by setup.php) ─────────────────
.setup-token

# ── OS files ─────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── JBrowse2 dev artifacts ──────────────────────────────────
/jbrowse2/node_modules/
/jbrowse2/dist/
/jbrowse2/.env

# ── JBrowse2 per-organism trix index output (generated at runtime) ──
# jbrowse text-index writes trix files to jbrowse2/{organism}/{assembly}/trix/
# The top-level trix/ dir is also generated.  The JBrowse2 app files
# (index.html, static/, etc.) are tracked above and are unaffected.
/jbrowse2/trix/
/jbrowse2/[A-Z]*/

# ── JBrowse CLI local install (project-local npm install, not in repo) ──
/tools/jbrowse-cli/

# ── Third-party tool archives and installations ──────────────
ncbi-blast-*
samtools-*

# ── Site-specific data directories ──────────────────────────
# Gene sets archived out of organisms/ by admin/api/archive_gene_set.php.
# Moved here (outside organisms/) so discovery routines don't scan them; it's
# site data (large FASTA/BLAST binaries), not app code.
/archived_gene_sets/
organisms_missing_data/
/moop/
smallscreen.png

# Self-hosted vendor assets (downloaded, not committed)
js/vendor/
css/fontawesome/
css/bootstrap.min.css
css/datatables/dataTables.bootstrap5.min.css
css/datatables/buttons.bootstrap5.min.css
css/datatables/colReorder.dataTables.min.css
