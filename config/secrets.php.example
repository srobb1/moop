<?php
/**
 * Site Secrets — API keys and credentials.  TEMPLATE.
 *
 * SETUP:
 *   cp config/secrets.php.example config/secrets.php
 *   then fill in the values you actually use and leave the rest as they are.
 *
 * This file is a template and IS committed. `config/secrets.php` is NOT committed
 * (.gitignore) — keep it private, and never paste real keys into this template.
 *
 * The whole file is OPTIONAL: config/site_config.php only reads it when it exists
 * (`if (file_exists($secrets_file))`), and every key below is read with a `??`
 * fallback. A deployment that uses neither Turnstile nor Galaxy can skip it entirely.
 *
 * Anything added here is copied to the site-data backup directory by
 * lib/housekeeping.php — that backup contains credentials, so keep it private too.
 */

return [

    // ── Cloudflare Turnstile — human verification for unauthenticated visitors ──
    // Only consulted when 'turnstile.enabled' is true (Admin → Site Configuration).
    // Get a key pair at https://dash.cloudflare.com/?to=/:account/turnstile
    //
    // NOTE: the SECRET key belongs here. The SITE key is not secret (it is emitted
    // into the page for the browser widget) and is normally set through the admin UI,
    // which stores it in config/config_editable.json. site_config.php will read a
    // site_key from here too if you prefer to keep the pair together.
    'turnstile' => [
        'site_key'   => '',   // public — optional here; usually set in the admin UI
        'secret_key' => '',   // PRIVATE — never commit, never send to the browser
    ],

    // ── Galaxy — bioinformatics workflow integration ──
    // Leave null to run without Galaxy. Create a key in Galaxy under
    // User → Preferences → Manage API Key.
    'galaxy' => [
        'api_key' => null,
    ],

];
